# Venice
VENICE_API_KEY=your_venice_api_key_here
VENICE_MODEL=qwen3-5-9b

# Base x402 service
# Modes: open-demo | payment-required | demo-bypass
AEGIS_X402_MODE=open-demo
AEGIS_X402_PAY_TO_ADDRESS=
AEGIS_X402_PRICE_USD=$0.05

# Optional local demo toggle
# Set to true only if you want `/api/evaluate/service` to accept
# an `X-PAYMENT` header without full facilitator verification.
# This is only used when AEGIS_X402_MODE is not open-demo.
AEGIS_X402_DEMO_BYPASS=false
